---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "Light Buoy",
    location: "Dumai",
    year: "2023",
    description:
      "Pelampung navigasi berlampu yang digunakan untuk menandai jalur, batas, atau bahaya di perairan.",
    image: "/images/buoy1.jpg",
  },
  {
    title: "Struktur",
    location: "Medan",
    year: "2022",
    description:
      "Fabrikasi dan pemasangan struktur baja untuk bangunan gudang industri.",
    image: "/images/struktur.jpg",
  },
  {
    title: "Economizer",
    location: "Bekasi",
    year: "2024",
    description:
      "Komponen boiler untuk memanfaatkan panas gas buang agar lebih hemat energi.",
    image: "/images/econom.jpg",
  },
  {
    title: "Pressure Vessel",
    location: "Jakarta",
    year: "2023",
    description:
      "Tangki bertekanan yang digunakan dalam sistem pengolahan air.",
    image: "/images/tim1.jpg",
  },
  {
    title: "Chimney",
    location: "Batam",
    year: "2022",
    description:
      "Cerobong yang berfungsi membuang gas atau asap dari sistem boiler ke udara.",
    image: "/images/chimney.jpg",
  },
 ];
---

<BaseLayout pageTitle="Galeri Proyek">
  <section class="gallery">
    <div class="container">
      <h1>Galeri Proyek</h1>

      <p class="subtitle">
        Beberapa proyek fabrikasi baja dan konstruksi yang telah kami kerjakan.
      </p>

      <div class="project-grid">
        {
          projects.map((project) => (
            <div class="project-card" data-image={project.image}>
              <img src={project.image} alt={project.title} />

              <div class="project-info">
                <h3>{project.title}</h3>

                <!-- 
                <p class="project-meta">
                  {project.location} • {project.year}
                </p>
                -->

                <p class="project-desc">{project.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- MODAL -->
  <div id="imageModal" class="modal">
    <span class="close">&times;</span>
    <img class="modal-content" id="modalImg" />
  </div>
</BaseLayout>

<style>
  .gallery {
    padding: 30px 0;
  }

  .container {
    max-width: 1200px;
    margin: auto;
    padding: 0 50px;
  }

  .gallery h1 {
    text-align: center;
    margin-bottom: 10px;
  }

  .subtitle {
    text-align: center;
    margin-bottom: 50px;
    color: #666;
  }

  /* GRID */

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 50px;
  }

  /* CARD */

  .project-card {
    background: #fff;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
    transition: transform 0.25s ease;
  }

  .project-card:hover {
    transform: translateY(-6px);
  }

  .project-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  .project-info {
    padding: 20px;
  }

  .project-info h3 {
    margin: 0 0 8px 0;
    font-size: 18px;
  }

  .project-meta {
    font-size: 14px;
    color: #777;
    margin-bottom: 10px;
  }

  .project-desc {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
  }

  /* MODAL */

  .modal {
    display: none;
    position: fixed;
    z-index: 1000;
    padding-top: 60px;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
  }

  .modal-content {
    display: block;
    margin: auto;
    max-width: 90%;
    max-height: 80vh;
  }

  .close {
    position: absolute;
    top: 20px;
    right: 35px;
    color: white;
    font-size: 40px;
    cursor: pointer;
  }

  /* RESPONSIVE */

  @media (max-width: 1000px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll(".project-card");
  const modal = document.getElementById("imageModal");
  const modalImg = document.getElementById("modalImg") as HTMLImageElement;
  const closeBtn = document.querySelector(".close");

  cards.forEach((card) => {
  card.addEventListener("click", () => {
    if (modal && modalImg) {
      modal.style.display = "block";
      modalImg.src = card.getAttribute("data-image") || ""; // ambil gambar dari data-image
    }
  });
});

  if (closeBtn && modal) {
    closeBtn.addEventListener("click", () => {
      modal.style.display = "none";
    });
  }

  if (modal) {
    modal.addEventListener("click", () => {
      modal.style.display = "none";
    });
  }
</script>

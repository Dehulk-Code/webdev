---
// src/layouts/BaseLayout.astro
import "../style/global.css"; // Import CSS global kita
import Header from "../components/Header.astro"; //import header
import Footer from "../components/Footer.astro"; //import footer

const { pageTitle } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/images/logoTGT.jpg"
    />
    <title>{pageTitle} - PT. Tapian Godang Tua</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
